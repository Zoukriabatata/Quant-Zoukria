# Copier ce fichier en secrets.toml et remplir les valeurs.
# Sur Streamlit Cloud : Settings > Secrets (coller le contenu directement).
# En local : .streamlit/secrets.toml (gitignore)

# Webhook Discord pour les alertes Live Signal
DISCORD_WEBHOOK = "https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN"

# Optionnel — ntfy.sh topic personnalisé
# NTFY_TOPIC = "hurst-mnq-ton-nom"
